DB_HOST=localhost
DB_PORT=5432
DB_NAME=knowvera
DB_USERNAME=admin
DB_PASSWORD=admin123

JWT_SECRET=replace-with-a-strong-secret-at-least-32-chars
JWT_EXPIRATION_MS=86400000

SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-smtp-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=no-reply@knowvera.local

VERIFY_BASE_URL=http://localhost:8080
VERIFY_TOKEN_TTL_HOURS=24
VERIFY_TOKEN_CLEANUP_MS=3600000

EMAIL_PROBE_MODE=soft
EMAIL_PROBE_TIMEOUT_MS=3000
EMAIL_PROBE_HELO=knowvera.local
EMAIL_PROBE_FROM=no-reply@knowvera.local

JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
